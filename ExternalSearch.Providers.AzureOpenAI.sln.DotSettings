	<s:Boolean x:Key="/Default/UserDictionary/Words/=ORBISID/@EntryIndexedValue">True</s:Boolean>
	<s:Boolean x:Key="/Default/UserDictionary/Words/=USSIC/@EntryIndexedValue">True</s:Boolean></wpf:ResourceDictionary>